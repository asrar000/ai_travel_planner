# ============================================
# AI Travel Planner - Environment Variables
# ============================================

# Get from: https://serper.dev/ (Free tier: 2500 searches)
SERPER_API_KEY=your_serper_api_key_here

# Get from: https://aistudio.google.com/app/apikey (Free)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Model selection (default is gemini-1.5-flash - free tier)
GEMINI_MODEL=gemini-1.5-flash
