# ============================================
# AI Travel Planner - Environment Variables
# ============================================

# Get from: https://serper.dev/ (Free tier: 2500 searches)
SERPER_API_KEY=your_serper_api_key_here

# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Optional key pool for auto-rotation on limit/auth errors (comma-separated)
# Example with 3 keys:
# GROQ_API_KEYS=gsk_key_1,gsk_key_2,gsk_key_3
GROQ_API_KEYS=

# Main model (requested)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: cheaper fallback model
GROQ_MODEL_FALLBACKS=llama-3.1-8b-instant

# Optional: retries per model before falling back
GROQ_RETRY_PER_MODEL=1

# Optional: low-token defaults to reduce cost/rate-limit risk
GROQ_MAX_TOKENS=280
GROQ_TIMEOUT_SECONDS=45
GROQ_TEMPERATURE=0.0

# Optional: retry backoff tuning for transient Groq errors (e.g., 429)
GROQ_RETRY_BACKOFF_BASE_SEC=3
GROQ_RETRY_BACKOFF_MAX_SEC=45

# Optional: CrewAI request-per-minute throttle
CREWAI_MAX_RPM=2

# Optional: keep Serper tool outputs compact (reduces LLM token load)
SERPER_RESULTS_LIMIT=2
SERPER_SNIPPET_MAX_CHARS=120
SERPER_INCLUDE_SNIPPET=false
