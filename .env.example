# ============================================
# AI Travel Planner - Environment Variables
# ============================================

# Get from: https://serper.dev/ (Free tier: 2500 searches)
SERPER_API_KEY=your_serper_api_key_here

# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Groq model selection
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: comma-separated fallback models if primary fails
GROQ_MODEL_FALLBACKS=llama-3.1-8b-instant

# Optional: retries per model before falling back
GROQ_RETRY_PER_MODEL=2

# Optional: cap response token size per LLM call (helps avoid TPM spikes)
GROQ_MAX_COMPLETION_TOKENS=700
GROQ_TIMEOUT_SECONDS=90

# Optional: retry backoff tuning for transient Groq errors (e.g., 429)
GROQ_RETRY_BACKOFF_BASE_SEC=3
GROQ_RETRY_BACKOFF_MAX_SEC=45

# Optional: CrewAI request-per-minute throttle
CREWAI_MAX_RPM=4

# Optional: keep Serper tool outputs compact (reduces LLM token load)
SERPER_RESULTS_LIMIT=3
SERPER_SNIPPET_MAX_CHARS=180
